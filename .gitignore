# ============================================================
#  C 언어 프로젝트용 .gitignore
# ============================================================

# ------------------------------
# 컴파일 결과물
# ------------------------------
*.exe
*.o
*.obj
*.out
*.a
*.lib
*.dll
*.so
*.dylib
a.out

# ------------------------------
# VS Code 개인 설정
# ------------------------------
.vscode/

# ------------------------------
# 디버그 / 임시 파일
# ------------------------------
*.pdb
*.ilk
*.exp
*.map
*.dSYM/

# ------------------------------
# 운영체제 자동 생성 파일
# ------------------------------
# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
*~

# ------------------------------
# 에디터 임시 파일
# ------------------------------
*.swp
*.swo
*.bak
*.tmp
